<Window x:Class="pielx.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pielx"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        Background="AliceBlue"
        Loaded="Window_Loaded"        
        >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="399*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="450"></RowDefinition>
            <RowDefinition Height="120"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Background="#0f0f2f" Grid.ColumnSpan="2" MouseDown="Grid_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="115*"/>
                <ColumnDefinition Width="115*"/>
                <ColumnDefinition Width="116*"/>
                <ColumnDefinition Width="184*"/>
                <ColumnDefinition Width="222*"/>
                <ColumnDefinition Width="48*"/>

            </Grid.ColumnDefinitions>
            <Image Source="Images/Logo.png"
                   Grid.Column="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   MouseDown="TextBlock_MouseDown" Height="28" Margin="0,1,74,1" Width="156" Grid.ColumnSpan="2"
                   >
            </Image>
            <Label Name="home"
                   Foreground="Wheat"
                   FontWeight="Bold"
                   FontSize="12"
                   Grid.Column="4" Margin="11,0,125,0"
                   >
                <TextBlock Width="40" PreviewMouseDown="TextBlock_PreviewMouseDown">
                      <Underline>Home</Underline>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property= "Foreground" Value="Wheat"/>
                            <Style.Triggers>
                                <Trigger Property ="IsMouseOver" Value="True">
                                    <Setter Property= "Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Label>
            <Label Name="howto"
                   Foreground="Wheat"
                   FontWeight="Bold"
                   FontSize="12"
                   Grid.Column="4" Margin="60,0,70,0">
                <TextBlock TextDecorations="Underline" PreviewMouseDown="TextBlock_PreviewMouseDown_1">
                    <Underline>How To?</Underline>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property= "Foreground" Value="Wheat"/>
                            <Style.Triggers>
                                <Trigger Property ="IsMouseOver" Value="True">
                                    <Setter Property= "Foreground" Value="White"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Label>
            <Label Name="donateLink"
                   Foreground="Wheat"
                   FontWeight="Bold"
                   FontSize="12"
                   Grid.Column="4" Margin="122,0,10,0">
                <TextBlock TextDecorations="Underline" PreviewMouseDown="TextBlock_PreviewMouseDown_2">
                     <Underline>Donate</Underline>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property= "Foreground" Value="Wheat"/>
                            <Style.Triggers>
                                <Trigger Property ="IsMouseOver" Value="True">
                                    <Setter Property= "Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Label>
            <Label Name="contact"
                   Foreground="Wheat"
                   FontWeight="Bold"
                   FontSize="12"
                   Grid.Column="4" Margin="177,0,10,0">
                <TextBlock TextDecorations="Underline" PreviewMouseDown="TextBlock_PreviewMouseDown_3">
                     <Underline>FAQ</Underline>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property= "Foreground" Value="Wheat"/>
                            <Style.Triggers>
                                <Trigger Property ="IsMouseOver" Value="True">
                                    <Setter Property= "Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Label>
            <Label Grid.Column="1"
                   Content="Mosaic Images from Videos Tool V1.0"
                   Foreground="White"
                   FontSize="15"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Top"
                   FontWeight="Bold" Grid.ColumnSpan="3" Margin="41,0,10,0"
                   >
            </Label>
            <Button Width="20" 
                    Grid.Column="5" 
                    HorizontalAlignment="Right"
                    MouseDown="Button_MouseDown" Margin="0,5"
                    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"></Setter>
                        <Setter Property="Cursor" Value="Hand"></Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Black"></Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>

                <Image Source="Images/close.png" 
                        Height="18" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        MouseDown="Button_MouseDown"
                       >
                    <Image.ToolTip>
                        <ToolTip>
                            Exit.
                        </ToolTip>
                    </Image.ToolTip>
                </Image>
            </Button>
            <Button Width="20" 
                    Grid.Column="5" 
                    HorizontalAlignment="Center"
                    MouseDown="Button_MouseDown" Margin="4,5,24,5"                    
                    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"></Setter>
                        <Setter Property="Cursor" Value="Hand"></Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Black"></Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Image x:Name="minimize" Source="Images/minimize.png" 
                   Height="18" 
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Center"
                   MouseDown="minimize_MouseDown"
                       >
                    <Image.ToolTip>
                        <ToolTip>
                            Minimizes Window.
                        </ToolTip>
                    </Image.ToolTip>
                </Image>
            </Button>
        </Grid>
        <TabControl HorizontalAlignment="Right" 
                    Height="450" 
                    Grid.Row="1" 
                    VerticalAlignment="Top" 
                    Width="800" 
                    Background="White"
                    x:Name="tabControl" Grid.ColumnSpan="2"
                    >
            <TabItem Background="Transparent" Width="100" x:Name="homeTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Images/home.png" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text=" Home" 
                                   Foreground="#0f0f2f" 
                                   FontWeight="Medium" 
                                   FontSize="16"
                                   FontFamily="Font/#StardosRegular"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"></RowDefinition>
                        <RowDefinition Height="320"></RowDefinition>
                        <RowDefinition Height="64"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="BlueViolet"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition ></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.Background>
                            <ImageBrush ImageSource="Images/back.png" Stretch="Uniform" AlignmentX="Right" AlignmentY="Center"/>
                        </Grid.Background>
                        <Label Content="Wellcome to                 " 
                               HorizontalAlignment="Left" 
                               Margin="5,32,0,0" 
                               VerticalAlignment="Top" 
                               Width="375"
                               FontWeight="ExtraBold"
                               FontSize="30"
                               Foreground="#3a0054"
                               HorizontalContentAlignment="Center"
                               />
                        <Image Source="Images/LogoOnpage.jpg" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="220,33,15,26" Width="162"/>
                        <TextBlock TextWrapping="WrapWithOverflow" 
                                   Margin="9,0,11,90" 
                                   Grid.RowSpan="2"
                                   FontWeight="ExtraBold"
                                   FontSize="15"
                                   Foreground="#3a0054"
                                   TextAlignment="Center" Grid.Row="1"
                                   >
                            VidsToPix is the best modern Mosaic Image Maker to create Mosaic images 
                            of various sizes using the videos you choose and 
                            any YouTube Videos you like. You can choose any 
                            video you like and then share it with your 
                            friends by obtaining mosaic images of various 
                            sizes for free. Now enjoy it.
                        </TextBlock>
                        <Button x:Name="NewProject"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Content="Start New Project"
                                FontSize="18"
                                FontWeight="Bold"                                        
                                PreviewMouseDown="NewProject_PreviewMouseDown"
                                Margin="100,44,100,22"
                                    Grid.Row="2"
                                    >
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Background" Value="DeepSkyBlue"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">

                                            <Setter Property="Background" Value="Blue"/>
                                            <Setter Property="Button.Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.5" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border CornerRadius="25" Width="190" Height="40" BorderBrush="BlueViolet"
                                        BorderThickness="1" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.3" />
                                        </Border.Effect>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.ToolTip>
                                <ToolTip>
                                    Starts a new Mosaic Image Project.
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="OpenoldProjects_Copy"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Content="Open Old Projects"
                            FontSize="15"
                            FontWeight="Bold"                                        
                            PreviewMouseDown="OpenoldProjects_PreviewMouseDown"
                            Margin="0,116,3,-55" Width="239"
                            Grid.Column="1" Grid.Row="2" Height="45"
                                    >
                            <Button.ToolTip>
                                <ToolTip>
                                    Opens Old Projects directory.
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Background" Value="DeepSkyBlue"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Blue"/>
                                            <Setter Property="Button.Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.5" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border CornerRadius="16" Width="160" Height="30" BorderBrush="BlueViolet"
                                        BorderThickness="1" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.3" />
                                        </Border.Effect>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button x:Name="browseProjectButton"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="..."
                                Foreground="White"
                                FontSize="20"
                                FontWeight="Bold"
                                Click="browseProjectButton_Click" 
                                Margin="260,0,0,0"
                                >
                            <Button.ToolTip>
                                <ToolTip>
                                    Choose project directory where you want to create.
                                </ToolTip>
                            </Button.ToolTip>
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Background" Value="LightSkyBlue"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="DeepSkyBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border CornerRadius="5" Width="30" Height="30" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center" >
                        <Border BorderBrush="Blue" BorderThickness="1">
                            <Label Content="Project Path: "
                               FontSize="15"
                               FontWeight="Black"
                               Foreground="DeepSkyBlue"
                                   >
                            </Label>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center" >
                        <Border BorderBrush="Blue" BorderThickness="1">
                            <Label Name="pathLbl" Content="..."
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="DeepSkyBlue"
                               Margin="110,0,0,0" Width="391"
                                   >
                            </Label>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Row="2"/>
                </Grid>
            </TabItem>
            <TabItem Background="Transparent" Width="150" x:Name="photoTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Images/selectPhoto.png" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="Select Photo" 
                                   Foreground="#0f0f2f" 
                                   FontWeight="Medium" 
                                   FontSize="16"
                                   FontFamily="Font/#StardosRegular"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>

                    </Grid.RowDefinitions>
                    <Grid Background="BlueViolet" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Grid Background="White" Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="312"></RowDefinition>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="White" Margin="10,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="450"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Image Source="Images/Home2.jpg" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,201,10,10" Height="89" Width="430"/>
                            </Grid>
                            <Grid Grid.Column="1" Background="White">
                                <StackPanel>
                                    <Image x:Name="photoImage" 
                                       Width="304" 
                                       Height="250"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Source="Images/select.png"
                                       Stretch="Uniform"
                                       MouseDown="photoImage_MouseDown" Margin="-9,30,45,25"
                                       Cursor="Hand"
                                           >
                                        <Image.ToolTip>
                                            <ToolTip>
                                                Select the photo you want to make Mosaic.
                                            </ToolTip>
                                        </Image.ToolTip>
                                    </Image>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Top" Margin="79,0,89,0" Width="166">
                                    <Label Name="photoSelectedLbl"
                                        Content="Photo Selected Succesfully"
                                           Foreground="Blue"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="-70,0,0,0" 
                                           Visibility="Hidden"
                                           >
                                    </Label>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="240,0,70,0" >
                                    <Image x:Name="photoSelectedImage" Source="Images/ok.png" Height="25" HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Visibility="Hidden"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Choose a main photo you wanted to make Mosaic." 
                                   HorizontalAlignment="Center" 
                                   Margin="10,35,10,0" 
                                   VerticalAlignment="Top" 
                                   RenderTransformOrigin="0.474,0.577"
                                   Foreground="BlueViolet"
                                   FontWeight="ExtraBold"
                                   FontSize="25" Width="430"
                                       TextWrapping="Wrap"
                                   />
                            <TextBlock HorizontalAlignment="Left" 
                                       Margin="10,155,0,0" 
                                       TextWrapping="Wrap" 
                                       Text="*Select a Square shaped photo for better results *Only Jpeg/Jpg file type is supported." 
                                       VerticalAlignment="Top"
                                       Foreground="IndianRed"
                                       FontWeight="DemiBold"
                                       FontSize="15" Width="345"
                                       />
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Column="0">
                                <Button x:Name="backtoHome"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Foreground="White"
                                        Content="Back"
                                        FontSize="25"
                                        FontWeight="Medium"
                                        PreviewMouseDown="backPage"
                                    Margin="0,10,0,0"
                                >
                                    <Button.ToolTip>
                                        <ToolTip>
                                            Back to Start New Project screen.
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Background" Value="DeepSkyBlue"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Blue"/>
                                                    <Setter Property="Button.Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.5" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="25" Width="120" Height="50" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.3" />
                                                </Border.Effect>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <Button x:Name="nextToSelectPhoto"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Foreground="White"
                                        Content="Next"
                                        FontSize="25"
                                        FontWeight="Medium"                                        
                                        PreviewMouseDown="nextPage"
                                    Margin="0,10,0,0" 
                                >
                                    <Button.ToolTip>
                                        <ToolTip>
                                            Next to Add Youtube Video screen.
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Background" Value="DeepSkyBlue"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Blue"/>
                                                    <Setter Property="Button.Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.5" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="25" Width="120" Height="50" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.3" />
                                                </Border.Effect>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Background="Transparent" Width="160" x:Name="youtubeVideoTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Images/youtube.png" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text=" Add YouTube" 
                                   Foreground="#0f0f2f" 
                                   FontWeight="Medium" 
                                   FontSize="16"
                                   FontFamily="Font/#StardosRegular"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Background="BlueViolet" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Grid Background="White" Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="312"></RowDefinition>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Column="0">
                                <Button x:Name="backtoPhotoSelect"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Foreground="White"
                                        Content="Back"
                                        FontSize="25"
                                        FontWeight="Medium"
                                        PreviewMouseDown="backPage"
                                        Margin="0,10,0,0"
                                    >
                                    <Button.ToolTip>
                                        <ToolTip>
                                            Back to Start Select Main Photo screen.
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Background" Value="DeepSkyBlue"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="Blue"/>
                                                    <Setter Property="Button.Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="5" Opacity="0.5" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="25" Width="120" Height="50" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
